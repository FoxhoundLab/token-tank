# Token Tank — Environment Variables (copy to .env and fill in values)

# Server
TOKEN_TANK_API_PORT=***  

# Proxy
TOKEN_TANK_PROXY_PORT=***  

# Crypto / Authentication
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_TANK_SECRET_KEY=***

# Optional Provider API Keys (pick what you need)
# ANTHROPIC_API_KEY=***       # Anthropic API key  (optional)
# ZAI_API_KEY=***             # Z.ai API key       (optional)
# MINIMAX_API_KEY=***         # MiniMax API key    (optional)
# OPENAI_API_KEY=***          # OpenAI API key     (optional)
